#!/bin/sh
set -eu

NOTEBOOKS="$(git diff --cached --name-only --diff-filter=ACMR | grep '\.ipynb$' || true)"

if [ -z "$NOTEBOOKS" ]; then
    exit 0
fi

python3 scripts/strip_notebook_output.py $NOTEBOOKS

printf '%s\n' "$NOTEBOOKS" | while IFS= read -r notebook; do
    if [ -n "$notebook" ]; then
        git add "$notebook"
    fi
done
